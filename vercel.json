{
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/dashboard",
      "destination": "/api/dashboard"
    },
    {
      "source": "/",
      "destination": "/api/dashboard"
    }
  ]
}
